# ─── Google Cloud project ──────────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_CLOUD_STORAGE_BUCKET=your-staging-bucket
GOOGLE_GENAI_USE_VERTEXAI=True

# Local Codespaces only — path to uploaded service account key.
# This SA authenticates Streamlit's calls to the Vertex AI Agent Engines
# API. It does NOT run any tools — the deployed agent does that under
# its own SPIFFE identity. Grant this SA roles/aiplatform.user.
GOOGLE_APPLICATION_CREDENTIALS=/tmp/sa-key.json

# ─── Deployed agent (set after running deploy.py) ──────────────────────────
# Format: projects/<num>/locations/<loc>/reasoningEngines/<id>
AGENT_ENGINE_RESOURCE_NAME=

# ─── Tool 1: Agent Identity → Cloud Storage ────────────────────────────────
# Lists buckets in GOOGLE_CLOUD_PROJECT. No extra config.

# ─── Tool 2: API key via Auth Manager → Resend ─────────────────────────────
AUTH_PROVIDER_RESEND=projects/your-project-id/locations/us-central1/connectors/resend-api-key
RESEND_FROM_EMAIL=demo@yourdomain.com
RESEND_TO_EMAIL=you@yourdomain.com

# ─── Tool 3: OAuth 2LO via Auth Manager → Microsoft Graph (app identity) ───
# Token URL: https://login.microsoftonline.com/<tenant-id>/oauth2/v2.0/token
# Scope:     https://graph.microsoft.com/.default
# App perm:  User.Read.All (admin-consented)
AUTH_PROVIDER_MSGRAPH_2LO=projects/your-project-id/locations/us-central1/connectors/msgraph-2lo

# ─── Tool 4: OAuth 3LO via Auth Manager → Microsoft Graph (delegated) ──────
# Authorization URL: https://login.microsoftonline.com/<tenant-id>/oauth2/v2.0/authorize
# Token URL:         https://login.microsoftonline.com/<tenant-id>/oauth2/v2.0/token
# Delegated scope:   User.Read offline_access
AUTH_PROVIDER_MSGRAPH_3LO=projects/your-project-id/locations/us-central1/connectors/msgraph-3lo

# Public URL of THIS Streamlit app — must match the redirect URI registered
# on the 3LO auth provider exactly.
# Codespaces example: https://<codespace>-8501.app.github.dev/
REDIRECT_URI=http://localhost:8501/
